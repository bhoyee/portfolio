<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve existing files and directories as-is (includes /api/*.php)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback (React Router) for everything else
  RewriteRule ^ index.html [L]
</IfModule>

